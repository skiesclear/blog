  <entry>
    <title>hexo_manual</title>
    <link href="/blog/2026/07/15/hexo-manual/"/>
    <url>/blog/2026/07/15/hexo-manual/</url>
    
    <content type="html"><![CDATA[<h1 id="Homepage-设置"><a href="#Homepage-设置" class="headerlink" title="Homepage 设置"></a>Homepage 设置</h1><h2 id="更新内容"><a href="#更新内容" class="headerlink" title="更新内容"></a>更新内容</h2><figure class="highlight gauss"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br></pre></td><td class="code"><pre><code class="hljs gauss"><span class="hljs-meta"># 运行目录 ~/workspace/homepage/HomePage</span><br>npm <span class="hljs-keyword">run</span> build<br><br>git <span class="hljs-keyword">push</span> -f origin master<br></code></pre></td></tr></table></figure><h1 id="单独的内容设置"><a href="#单独的内容设置" class="headerlink" title="单独的内容设置"></a>单独的内容设置</h1><h2 id="环境配置"><a href="#环境配置" class="headerlink" title="环境配置"></a>环境配置</h2><p>hexo</p><figure class="highlight avrasm"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs avrasm">npm install -g hexo-<span class="hljs-keyword">cli</span><br></code></pre></td></tr></table></figure><h2 id="Blog-设置"><a href="#Blog-设置" class="headerlink" title="Blog 设置"></a>Blog 设置</h2><h3 id="初始化项目"><a href="#初始化项目" class="headerlink" title="初始化项目"></a>初始化项目</h3><figure class="highlight jboss-cli"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br><span class="line">30</span><br><span class="line">31</span><br><span class="line">32</span><br><span class="line">33</span><br><span class="line">34</span><br><span class="line">35</span><br><span class="line">36</span><br><span class="line">37</span><br><span class="line">38</span><br><span class="line">39</span><br><span class="line">40</span><br></pre></td><td class="code"><pre><code class="hljs jboss-cli"><span class="hljs-comment"># 运行目录 ~/workspace/homepage</span><br>hexo init blog<br><br><span class="hljs-keyword">cd</span> blog/<br><br>npm install<br><br><span class="hljs-comment"># 下载主题</span><br>git clone https:<span class="hljs-string">//github.com/SimonAKing/hexo-theme-tomotoes.git</span> themes/tomotoes<br><br><span class="hljs-comment"># 安装配置</span><br> npm install hexo-renderer-less <span class="hljs-params">--save</span><br> npm install hexo-renderer-ejs <span class="hljs-params">--save</span><br><br><span class="hljs-comment"># 编译项目，内容放在 /public目录下</span><br>npx hexo clean<br>npx hexo generate<br><br><span class="hljs-comment"># 主题太旧，更新主题</span><br>npm install <span class="hljs-params">--save</span> hexo-theme-fluid<br><br><span class="hljs-comment"># 设置新主题</span><br>cp node_modules/hexo-theme-fluid/_config.yml _config.fluid.yml<br>vim _config.yml<br><br>npm install <span class="hljs-params">--save</span> \<br>  hexo-renderer-marked \<br>  hexo-renderer-ejs \<br>  hexo-generator-index \<br>  hexo-generator-archive \<br>  hexo-generator-category \<br>  hexo-generator-tag<br><br><br><span class="hljs-comment"># 实现自动部署，不需要git 推送</span><br><br>npm install <span class="hljs-params">--save</span> hexo-deployer-git<br><br><span class="hljs-comment"># 配置_config.yml 中的deploy</span><br>npx hexo <span class="hljs-keyword">deploy</span><br></code></pre></td></tr></table></figure><h3 id="添加新内容"><a href="#添加新内容" class="headerlink" title="添加新内容"></a>添加新内容</h3><figure class="highlight verilog"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br></pre></td><td class="code"><pre><code class="hljs verilog"># 运行目录 ~/workspace/homepage/blog<br># 生成文件<br>npx hexo <span class="hljs-keyword">new</span> post <span class="hljs-string">&quot;hexo_manual&quot;</span><br><br># 编译并部署到github<br>npx hexo clean<br>npx hexo <span class="hljs-keyword">generate</span><br>npx hexo deploy<br></code></pre></td></tr></table></figure><h2 id="Academia-设置"><a href="#Academia-设置" class="headerlink" title="Academia 设置"></a>Academia 设置</h2><p>与blog类似</p><figure class="highlight bash"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br><span class="line">30</span><br><span class="line">31</span><br><span class="line">32</span><br></pre></td><td class="code"><pre><code class="hljs bash"><span class="hljs-comment"># 运行目录 ~/workspace/homepage</span><br>npx hexo init academic<br><span class="hljs-built_in">cd</span> academic<br><br><span class="hljs-comment"># 设置主题</span><br>git <span class="hljs-built_in">clone</span> https://github.com/PhosphorW/hexo-theme-academia.git themes/Academia<br><br><span class="hljs-comment"># 增加主题所需配置</span><br>npm install --save hexo-renderer-pug hexo-renderer-stylus<br>npm install --save hexo-renderer-marked<br><br><span class="hljs-comment"># 修改项目配置 </span><br>vim _config.yml<br><br><span class="hljs-comment"># 修改主题配置</span><br>vim themes/Academia/_config.yml<br><br><span class="hljs-comment"># 增加资源目录</span><br><span class="hljs-built_in">mkdir</span> -p <span class="hljs-built_in">source</span>/images<br><span class="hljs-built_in">mkdir</span> -p <span class="hljs-built_in">source</span>/files<br><br><br><span class="hljs-comment"># 运行目录 ~/workspace/homepage/blog</span><br><span class="hljs-comment"># 生成文件</span><br>npx hexo new post <span class="hljs-string">&quot;hexo_manual&quot;</span><br><br><span class="hljs-comment"># 编译并部署到github</span><br>npm install --save hexo-deployer-git<br><br>npx hexo clean<br>npx hexo generate<br>npx hexo deploy<br></code></pre></td></tr></table></figure>]]></content>
    
    
    
